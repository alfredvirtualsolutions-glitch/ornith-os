# Ornith OS — environment variables (set these in the Vercel project settings).
# Copy to .env for local runs; never commit real secrets.

# Neon Postgres connection string (use the pooled -pooler endpoint).
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DB?sslmode=require

# Ornith-1.0 OpenAI-compatible endpoint (vLLM / SGLang). Leave unset to run the
# app with model calls disabled (the API still works; chat returns a notice).
ORNITH_BASE_URL=
ORNITH_API_KEY=
ORNITH_MODEL=Ornith-1.0

# Optional sampling overrides.
ORNITH_TEMPERATURE=0.6
ORNITH_TOP_P=0.95
ORNITH_MAX_TOKENS=2048
