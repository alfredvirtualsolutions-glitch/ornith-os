# Ornith OS — local development secrets.
#
# Copy this file to `.dev.vars` (which is git-ignored) and fill in your values.
# `wrangler dev` loads .dev.vars automatically. For production, set the same
# keys as secrets: `wrangler secret put ORNITH_API_KEY`.
#
# Leave these unset/empty to run entirely on Cloudflare Workers AI (no GPU,
# no external endpoint). Set them to route the agent's "brain" to a real
# Ornith-1.0 server exposing an OpenAI-compatible /v1 API (vLLM / SGLang).

# Base URL of your Ornith OpenAI-compatible server, INCLUDING the /v1 suffix.
# Example: https://my-gpu-host.example.com/v1
ORNITH_BASE_URL=

# API key for the Ornith endpoint. For a local vLLM/SGLang server any non-empty
# string works (the servers accept "EMPTY").
ORNITH_API_KEY=
